{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run mmd File",
      "type": "shell",
      "command": "mmdc -i ${file} -o ${input:output1} -w 1200 -H 800 --scale 2 ",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ],
  "inputs": [
    {
      "id": "output1",
      "type": "promptString",
      "description": "Enter mermaid output file (png):",
      "default": "v1.0.0"
    },
  ]
}